SANITY_STUDIO_PROJECT_ID=your_project_id_here
SANITY_STUDIO_DATASET=production

# Only needed to run `npm run import-data` (the one-time migration script).
# Create at https://www.sanity.io/manage -> your project -> API -> Tokens
# (Editor permissions). Never commit the real token.
SANITY_WRITE_TOKEN=your_write_token_here
